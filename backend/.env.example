# ═══════════════════════════════════════════════════════════
# DOCUMENT RAG CHATBOT — BACKEND ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────
APP_NAME="Document RAG Chatbot"
APP_VERSION="1.0.0"
DEBUG=true                        # Set to false in production
ENVIRONMENT=development           # development | staging | production

# Server settings
HOST=0.0.0.0
PORT=8000
WORKERS=1                         # Increase in production

# ─────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ─────────────────────────────────────────────
# Which frontend URLs are allowed to call this backend
# Development: your Next.js dev server
# Production: your Vercel URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─────────────────────────────────────────────
# FREE LLM CONFIGURATION
# ─────────────────────────────────────────────
# Choose ONE primary provider. The other is a fallback.

# Option A: Google Gemini (RECOMMENDED — larger free quota)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Groq — Llama 3.1 70B (faster, lower daily limit)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use: "gemini" or "groq"
LLM_PROVIDER=gemini

# LLM Model names (change if newer models are available)
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-70b-versatile

# ─────────────────────────────────────────────
# FREE EMBEDDING CONFIGURATION
# ─────────────────────────────────────────────
# Option A: HuggingFace Inference API (cloud, free tier)
# Get token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here

# Option B: Local sentence-transformers (no API needed)
# Runs on your machine, ~90MB model download on first use

# Which embedding provider: "huggingface" or "local"
EMBEDDING_PROVIDER=local

# Embedding model name (same model, both providers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────
# VECTOR DATABASE CONFIGURATION
# ─────────────────────────────────────────────
# Which vector DB to use: "chroma" or "qdrant"
VECTOR_DB_PROVIDER=chroma

# Chroma settings (local development)
CHROMA_PERSIST_DIR=./chroma_db    # Where Chroma saves data on disk
CHROMA_COLLECTION_NAME=documents

# Qdrant settings (production cloud)
# Get free cluster at: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=documents

# ─────────────────────────────────────────────
# FILE UPLOAD SETTINGS
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads              # Temp directory for uploaded files
MAX_FILE_SIZE_MB=50               # Maximum file size in megabytes
ALLOWED_EXTENSIONS=pdf,docx,txt   # Comma-separated allowed file types

# ─────────────────────────────────────────────
# RAG / CHUNKING SETTINGS
# ─────────────────────────────────────────────
CHUNK_SIZE=1000                   # Characters per chunk
CHUNK_OVERLAP=200                 # Overlap between chunks
MAX_RETRIEVAL_DOCS=5              # How many chunks to retrieve per query
MIN_RELEVANCE_SCORE=0.3           # Minimum similarity score (0-1)

# ─────────────────────────────────────────────
# SECURITY (add these in Phase 7)
# ─────────────────────────────────────────────
SECRET_KEY=your_secret_key_here   # Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_HEADER=X-API-Key          # Header name for API key auth