# ═══════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
#
# Note: Variables MUST start with NEXT_PUBLIC_ to be
# accessible in the browser. Server-only variables don't
# need this prefix.
# ═══════════════════════════════════════════════════════════

# Backend API URL
# Development: your local FastAPI server
# Production: your Render deployment URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# App configuration
NEXT_PUBLIC_APP_NAME="Document RAG Chatbot"
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50

# Feature flags (optional)
NEXT_PUBLIC_ENABLE_STREAMING=true
NEXT_PUBLIC_ENABLE_MULTI_DOC=true